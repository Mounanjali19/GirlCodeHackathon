# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in many locales; however, for an application the files might be
#   used and kept for later installation.
.python-version
.pyenv-version
.pyenv-python-version

# pipenv
#   According to pypi packaging standards, .venv/ directories should be excluded from source control,
#   except in the case of a bundled library or application (i.e. with a requirements.txt).  The latter
#   scenario could occur when using pipenv to install a library from a Git repository.
Pipfile.lock

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

